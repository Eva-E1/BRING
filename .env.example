# =============================================================================
# World Explorer Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Then run the server with:
#   python -m uvicorn world_explorer.api:app --host 127.0.0.1 --port 8000 --reload
# =============================================================================

# ── LLM (Language Model) Configuration ─────────────────────────────────────
# Base URL for your LLM API (OpenAI-compatible)
# Examples:
#   - http://localhost:20128/v1 (Liara local)
#   - https://api.openai.com/v1 (OpenAI)
#   - http://localhost:11434/v1 (Ollama)
#   - https://api.mistral.ai/v1 (Mistral)
WORLD_LLM_BASE_URL=http://localhost:20128/v1

# Your API key
WORLD_LLM_API_KEY=sk-your-api-key-here

# Model to use (must be compatible with your LLM provider)
# Examples: gpt-4o-mini, gpt-4o, llama3, mistral-small
WORLD_LLM_MODEL=gpt-4o-mini

# ── Embedding Configuration ─────────────────────────────────────────────────
# (Optional) Separate embedding service if different from LLM
# WORLD_EMBEDDING_BASE_URL=http://localhost:8043/v1
# WORLD_EMBEDDING_API_KEY=
# WORLD_EMBEDDING_MODEL=text-embedding-3-small

# ── Database Configuration ─────────────────────────────────────────────────-
# Path to the world database (entities, graph, etc.)
WORLD_DB_PATH=./world_db

# ── Server Configuration ───────────────────────────────────────────────────
# WORLD_SERVER_HOST=127.0.0.1
# WORLD_SERVER_PORT=8000

# ── Behavior Configuration ─────────────────────────────────────────────────
# Enable automatic graph repair on startup
WORLD_AUTO_HEAL=true

# ── Advanced LLM Settings ─────────────────────────────────────────────────-
# WORLD_LLM_TIMEOUT=120.0
# WORLD_LLM_MAX_TOKENS=4096
# WORLD_LLM_TEMPERATURE=0.7
# WORLD_LLM_MAX_RETRIES=3
# WORLD_LLM_MAX_CONCURRENT=8
