# Shared BRING configuration

# LLM gateway
LLM_PROVIDER=openai
LLM_PROVIDER_TYPE=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_key_here
LLM_BASE_URL=
LLM_API_VERSION=
LLM_ORGANIZATION=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# Embeddings
LLM_EMBEDDING_PROVIDER=openai
LLM_EMBEDDING_PROVIDER_TYPE=openai
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_EMBEDDING_DIM=1536
LLM_EMBEDDING_API_KEY=
LLM_EMBEDDING_BASE_URL=
LLM_EMBEDDING_API_VERSION=
LLM_EMBEDDING_ORGANIZATION=

# Memory
MEMORY_DATABASE_ROOT=./memory_databases
MEMORY_DATABASE_ID=default
# Optional explicit override; leave empty to use MEMORY_DATABASE_ROOT/MEMORY_DATABASE_ID.
MEMORY_KUZU_DB_PATH=
MEMORY_GRAPHITI_MAX_COROUTINES=10
MEMORY_GRAPHITI_STORE_RAW_EPISODES=true
MEMORY_STRUCTURED_EXTRACTION=true
MEMORY_BULK_BATCH=5
MEMORY_SEARCH_RESULT_LIMIT=50
MEMORY_TIMELINE_WINDOW=30
MEMORY_SEARCH_CACHE_TTL_SECONDS=120
MEMORY_SEARCH_CACHE_MAXSIZE=256
