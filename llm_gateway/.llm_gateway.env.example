# Copy this file to `.llm_gateway.env` and fill in the real values.
# The loader reads `.llm_gateway.env` by default, or the path in
# `LLM_GATEWAY_SETTINGS_FILE`.

LLM_PROVIDER=openai
LLM_PROVIDER_TYPE=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=replace-me
LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_VERSION=
# LLM_ORGANIZATION=
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024
